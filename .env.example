# Root environment for docker-compose. Copy to .env and customize.
# Credentials are read from here — nothing is hard-coded in the images.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=inventory
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=3000

# CORS: "*" for local dev, or a comma-separated list of allowed origins.
CORS_ORIGINS=*
