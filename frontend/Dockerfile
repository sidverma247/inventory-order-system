# ---- build stage ----
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json ./
RUN npm install
COPY . .
# Optional: bake an absolute API base URL at build time (for split hosting).
# Left empty by default so the nginx reverse proxy below handles /api.
ARG VITE_API_BASE_URL=""
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN npm run build

# ---- serve stage ----
FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/templates/default.conf.template
COPY --from=build /app/dist /usr/share/nginx/html
# BACKEND_URL is templated into nginx.conf at container start.
ENV BACKEND_URL=http://backend:8000
ENV PORT=80
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
